# Prodamus Configuration
# Your Prodamus store URL (e.g., https://yourstore.payform.ru)
PRODAMUS_URL=
# Your Prodamus secret key for webhook verification
PRODAMUS_SECRET_KEY=

# Telegram Configuration
# Telegram Bot Token from BotFather
TELEGRAM_BOT_TOKEN=
# Telegram Chat ID for the group (e.g., -1003978251165)
TELEGRAM_CHAT_ID=-1003978251165
# Telegram Topic ID (message_thread_id)
TELEGRAM_TOPIC_ID=4
# Optional: comma-separated admin user ids allowed to reply from topics
TELEGRAM_ADMIN_IDS=
# Optional: welcome image for /start
TELEGRAM_WELCOME_IMAGE_URL=
# Optional: Telegram file_id for the audio practice
TELEGRAM_AUDIO_FILE_ID=
# Optional: public URL for the audio practice if file_id is not used
TELEGRAM_AUDIO_URL=

# Public site URL used in bot buttons
PUBLIC_SITE_URL=https://otragenie-camp.ru

# Optional delays in milliseconds
BOT_FEELING_DELAY_MS=600000
BOT_FOLLOWUP_DELAY_MS=86400000
